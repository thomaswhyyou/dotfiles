theme = Xcode Dark

font-family = Berkeley Mono Condensed
font-size = 12
font-feature = -calt, -liga, -dlig

cursor-color = 05f900
cursor-text = 003541
custom-shader = shaders/cursor_sweep.glsl

macos-non-native-fullscreen = true
mouse-hide-while-typing = true
window-padding-balance = true

# Tmux bindings
# Reference: https://github.com/mxgrn/dotfiles/tree/master/.config/ghostty

# cmd+t to create a new tmux window
keybind = super+t=text:\x13c

# cmd+x to close the current pane
keybind = super+x=text:\x13x

# cmd+l to toggle between two latest windows
keybind = super+l=text:\x13l

# cmd+n to go to the corresponding tmux window
keybind = super+digit_1=text:\x131
keybind = super+digit_2=text:\x132
keybind = super+digit_3=text:\x133
keybind = super+digit_4=text:\x134
keybind = super+digit_5=text:\x135
keybind = super+digit_6=text:\x136
keybind = super+digit_7=text:\x137
keybind = super+digit_8=text:\x138
keybind = super+digit_9=text:\x139

# cmd+shfit+left|right to go to next/prev tmux window
keybind = super+alt+right=text:\x13n
keybind = super+alt+left=text:\x13p

# cmd+shfit+alt+left|right to move the current tmux window left/right
# (requires the custom tmux bindings in .tmux.conf)
keybind = super+shift+alt+right=text:\x13N
keybind = super+shift+alt+left=text:\x13P
